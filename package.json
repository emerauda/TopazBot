{
	"name": "fetherbot",
	"version": "1.3.0",
	"description": "A TopazChat RTSP to Discord voice channel relay bot using @discordjs/voice",
	"main": "dist/index.js",
	"private": true,
	"scripts": {
		"start": "node dist/index.js",
		"build": "tsc",
		"dev": "ts-node src/index.ts",
		"register": "node register.js"
	},
	"keywords": [
		"discord",
		"discord-bot",
		"topazbot",
		"topazchat",
		"rtsp",
		"voice",
		"music-bot",
		"opus",
		"ffmpeg"
	],
	"author": "Aoi Emerauda <aoi@emerauda.com>",
	"license": "MIT",
	"repository": {
		"type": "git",
		"url": "git+https://github.com/emerauda/TopazBot.git"
	},
	"bugs": {
		"url": "https://github.com/emerauda/TopazBot/issues"
	},
	"homepage": "https://github.com/emerauda/TopazBot#readme",
	"engines": {
		"node": ">=22"
	},
	"dependencies": {
		"@discordjs/opus": "^0.10.0",
		"@discordjs/voice": "^0.19.2",
		"@snazzah/davey": "^0.1.12",
		"discord.js": "^14.26.5",
		"sodium-native": "^5.1.0"
	},
	"devDependencies": {
		"@types/node": "^26.1.1",
		"ts-node": "^10.9.2",
		"typescript": "^6.0.3"
	},
	"overrides": {
		"undici": "^6.27.0",
		"tar": "^7.5.20"
	}
