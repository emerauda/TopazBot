###############################################
# FetherBot (TopazBot legacy single-guild branch) .env example
# Replace the values on the right with ones for your environment.
###############################################

# Discord Bot token (required)
DISCORD_TOKEN=your_discord_bot_token_here

# Stream name prefix (required). The fixed stream key is STREAM + NUMBER.
STREAM=your_stream_name

# Bot number used as the command-name suffix (optional).
# Example: NUMBER=2 -> commands /play2, /resync2, /stop2 and stream key <STREAM>2
# Leave empty for /play, /resync, /stop.
NUMBER=

# Voice channel ID to auto-join when a user enters it (optional, empty disables)
TARGET_VOICE_CHANNEL_ID=

# RTSP server base URL (optional). The bot appends /<streamkey> to it.
# Default: rtsp://topaz.chat/live
# RTSP_SERVER_URL=rtsp://topaz.chat/live
