###############################################
# TopazBot .env example
# Replace the values on the right with ones for your environment.
# Unused options can be removed or commented out.
###############################################

########################
# Discord basics
########################
# Discord Bot token (required)
DISCORD_TOKEN=your_discord_bot_token_here

########################
# RTSP input
########################
# RTSP base URL (the bot appends /<streamkey> to it)
# Default: rtsp://topaz.chat/live
RTSP_SERVER_URL=rtsp://topaz.chat/live
# Examples:
# RTSP_SERVER_URL=rtsp://stream.vrcdn.live/live
# RTSP_SERVER_URL=rtsp://192.168.1.100:8554/live

########################
# Audio output mode
########################
# Produce Opus (Ogg) directly with external FFmpeg (recommended).
# Set to 0 for AAC (ADTS) output, which discord.js re-encodes on its side.
USE_EXTERNAL_OPUS=1
# Set to 1 ONLY if your RTSP source actually delivers Opus audio — then the
# bot remuxes with -c:a copy instead of re-encoding. TopazChat and VRCDN
# deliver AAC, so keep this at 0. (If misconfigured, the bot detects the
# failure and falls back to re-encoding automatically.)
INPUT_IS_OPUS=0
# Disable the copy path and always re-encode (for noise workarounds / filters)
FORCE_OPUS_REENCODE=0

########################
# Quality / bitrate
########################
# Target Opus bitrate (FFmpeg -b:a). Examples: 128k / 160k / 192k / 256k
OPUS_BITRATE=192k
# Bitrate for the AAC fallback. Falls back to OPUS_BITRATE when unset.
# AAC_BITRATE=192k

########################
# Channel handling / debugging
########################
# Set DOWNMIX_MONO=1 to downmix the input to mono (-ac 1) and send it as is.
DOWNMIX_MONO=0
# Discard corrupt frames and regenerate PTS (also applied in copy mode).
# Combined with low latency mode this adds +nobuffer as well.
COPY_WITH_DISCARDCORRUPT=1
# Channel fix mode: none|swap|left|right|mix
CHANNEL_FIX_MODE=none
# Show FFmpeg debug logs (spawn args and stderr)
DEBUG_FFMPEG=0

########################
# Low latency
########################
# Reduce RTSP/FFmpeg buffering and analysis time.
# Set to 1 to add nobuffer / analyzeduration=0 / max_delay=0 / 20ms ogg pages.
LOW_LATENCY=1
# Time to wait (ms) before playback is considered stable.
# Defaults to 300ms when LOW_LATENCY=1. Only set to override.
# PLAY_WAIT_MS=300
# Wait (ms) before an automatic resume (retry). Defaults to 500ms when LOW_LATENCY=1.
# RESUME_WAIT_MS=500

########################
# Forced re-encode / filters (only when needed)
########################
# If you want channel fixes or downmixing but INPUT_IS_OPUS=1 selects the copy
# path, set FORCE_OPUS_REENCODE=1 to force the re-encode path.

###############################################
# Recommended set for TopazChat (AAC input, lowest latency):
#   USE_EXTERNAL_OPUS=1
#   INPUT_IS_OPUS=0
#   FORCE_OPUS_REENCODE=0
#   LOW_LATENCY=1
#   OPUS_BITRATE=192k
#   CHANNEL_FIX_MODE=none
###############################################

###############################################
# Video relay (video-stream branch, `npm run video`) — EXPERIMENTAL
#
# WARNING: Discord blocks video from BOT accounts, so the video relay needs a
# USER token (selfbot). Automating a user account violates Discord's Terms of
# Service and can get it PERMANENTLY BANNED. Use a THROWAWAY account only.
# The audio bot above uses a normal bot token and is unaffected by this.
###############################################
# User (selfbot) account token — NOT the bot token above.
USER_TOKEN=your_selfbot_user_token_here
# Target guild (server) and voice channel IDs to Go Live in.
VIDEO_GUILD_ID=your_guild_id_here
VIDEO_CHANNEL_ID=your_voice_channel_id_here
# TopazChat stream key. The RTSP URL becomes ${RTSP_SERVER_URL}/${STREAM_KEY}.
STREAM_KEY=your_stream_key_here

# --- Video encoding (all optional; defaults shown) ---
# Output resolution sent to Discord.
# VIDEO_WIDTH=1920
# VIDEO_HEIGHT=1080
# Frame rate.
# VIDEO_FPS=30
# Target / max video bitrate in kbps.
# VIDEO_BITRATE=5000
# VIDEO_BITRATE_MAX=7500
# Video codec: H264 (default) | H265 | VP8
# VIDEO_CODEC=H264
# LOW_LATENCY (shared with the audio bot) and DEBUG_FFMPEG=1 also apply here.

########################
# Video relay (video-stream branch only, npm run video)
########################
# ⚠️ Discord blocks video from bot accounts. The video relay ther
